model NotificationSettings {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  upvote   Boolean @default(true)
  downvote Boolean @default(true)

  answerCreated Boolean @default(true)
  replyCreated  Boolean @default(true)

  answerAccepted   Boolean @default(true)
  answerMarkedBest Boolean @default(true)

  aiSuggestionUnlocked Boolean @default(true)
  aiAnswerUnlocked     Boolean @default(true)

  similarQuestionsReady Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
