  MATLAB
  GROOVY
  POWERSHELL
  BASH
  VBSCRIPT
  ASSEMBLY
  FORTRAN
  COBOL

  HTML
  CSS
  ANGULAR
  REACT
  VUE_JS      @map("VUE.JS")
  JQUERY
  BOOTSTRAP
  SVELTE
  NEXT_JS     @map("NEXT.JS")
  NUXT_JS     @map("NUXT.JS")
