# Server

PORT=5000
NODE_ENV=development
STAGE=DEMO

# JWT

JWT_SECRET=your_jwt_secret_here

# Google OAuth

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# PostgreSQL

DATABASE_URL=your_database_url_here
DIRECT_URL=your_direct_database_url_here

# MongoDB

MONGO_URI=your_mongo_uri_here

MONGO_ATLAS_RECOMMENDED_QUESTIONS_INDEX=recommended_index
MONGO_ATLAS_QUESTION_AUTOCOMPLETE_INDEX=questions_autocomplete
MONGO_ATLAS_QUESTION_SEARCH_INDEX=search_index
MONGO_ATLAS_QUESTION_VECTOR_SEARCH_INDEX=semantic_search_vector_index

# Redis

REDIS_CACHE_URL=your_redis_cache_url_here
REDIS_MESSAGING_URL=your_redis_messaging_url_here

# Credits

DAILY_CREDIT_LIMIT=400
WEEKLY_CREDIT_LIMIT=1600

# SMTP / Email

SMTP_HOST=your_smtp_host_here
SENDER_EMAIL=your_sender_email_here
SENDER_PASS=your_sender_password_here
QANOPY_EMAIL=your_qanopy_email_here

SUPPORT_EMAIL=your_support_email_here

# AWS S3 / CloudFront

BUCKET_NAME=your_bucket_name_here
BUCKET_REGION=your_bucket_region_here
ACCESS_KEY=your_access_key_here
SECRET_ACCESS_KEY=your_secret_access_key_here
CLOUDFRONT_DOMAIN=your_cloudfront_domain_here

# LLMs

OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
VOYAGE_API_KEY=your_voyage_api_key_here

